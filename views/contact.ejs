<div class="max-w-2xl mx-auto fade-up">
  <h1 class="text-2xl font-bold mb-6">📬 تواصل معنا</h1>

  <% if (typeof success !== 'undefined') { %>
    <div class="bg-green-900/30 border border-green-700/50 text-green-300 rounded-xl p-4 mb-6 text-center text-sm"><%= success %></div>
  <% } %>
  <% if (typeof error !== 'undefined') { %>
    <div class="bg-red-900/30 border border-red-700/50 text-red-300 rounded-xl p-4 mb-6 text-center text-sm"><%= error %></div>
  <% } %>

  <div class="grid md:grid-cols-2 gap-6">
    <div class="bg-dark-800/60 border border-dark-700/40 rounded-2xl p-6">
      <p class="text-gray-400 mb-4 text-sm">لأي استفسارات أو طلبات حذف بيانات، تواصل معنا:</p>
      <div class="space-y-3">
        <a href="mailto:info@ksawats.com" class="flex items-center gap-3 text-gray-300 hover:text-white transition p-3 bg-dark-700/50 rounded-xl">
          <span class="text-xl">📧</span> info@ksawats.com
        </a>
        <a href="https://ksawats.com" target="_blank" class="flex items-center gap-3 text-gray-300 hover:text-white transition p-3 bg-dark-700/50 rounded-xl">
          <span class="text-xl">🌐</span> ksawats.com
        </a>
      </div>
    </div>

    <form action="/contact" method="POST" class="bg-dark-800/60 border border-dark-700/40 rounded-2xl p-6 space-y-4">
      <h2 class="font-bold text-lg">أرسل رسالة</h2>
      <div>
        <label class="block text-sm text-gray-400 mb-1">الاسم <span class="text-brand-400">*</span></label>
        <input type="text" name="name" required class="w-full bg-dark-700 border border-dark-600 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-brand-500 transition">
      </div>
      <div>
        <label class="block text-sm text-gray-400 mb-1">البريد الإلكتروني <span class="text-brand-400">*</span></label>
        <input type="email" name="email" required class="w-full bg-dark-700 border border-dark-600 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-brand-500 transition">
      </div>
      <div>
        <label class="block text-sm text-gray-400 mb-1">الموضوع</label>
        <input type="text" name="subject" class="w-full bg-dark-700 border border-dark-600 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-brand-500 transition">
      </div>
      <div>
        <label class="block text-sm text-gray-400 mb-1">الرسالة <span class="text-brand-400">*</span></label>
        <textarea name="message" rows="4" required class="w-full bg-dark-700 border border-dark-600 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-brand-500 transition resize-none"></textarea>
      </div>
      <button type="submit" class="w-full bg-brand-600 hover:bg-brand-700 py-3 rounded-xl font-bold text-sm transition">📤 إرسال</button>
    </form>
  </div>
</div>
