<div class="fade-up">
  <div class="text-center mb-8">
    <div class="text-5xl mb-3">📊</div>
    <h1 class="text-3xl font-bold mb-2">إحصائياتي</h1>
    <p class="text-gray-400">تتبع مساهماتك على الموقع</p>
  </div>

  <% if (!stats) { %>
    <div class="text-center py-16 text-gray-500">
      <div class="text-5xl mb-4">🤷</div>
      <p>لم تساهم بعد! <a href="/submit" class="text-brand-400 hover:text-brand-300 font-bold">شارك تجربتك الآن</a></p>
    </div>
  <% } else { %>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="bg-dark-900 border border-dark-800 rounded-2xl p-5 text-center">
        <div class="text-3xl mb-1">✍️</div>
        <div class="text-2xl font-bold text-brand-400"><%= stats.storiesCount %></div>
        <div class="text-xs text-gray-500">تجارب مرسلة</div>
      </div>
      <div class="bg-dark-900 border border-dark-800 rounded-2xl p-5 text-center">
        <div class="text-3xl mb-1">💬</div>
        <div class="text-2xl font-bold text-blue-400"><%= stats.commentsCount %></div>
        <div class="text-xs text-gray-500">تعليقات</div>
      </div>
      <div class="bg-dark-900 border border-dark-800 rounded-2xl p-5 text-center">
        <div class="text-3xl mb-1">❤️</div>
        <div class="text-2xl font-bold text-pink-400"><%= stats.totalReactions %></div>
        <div class="text-xs text-gray-500">تفاعلات على تجاربك</div>
      </div>
      <div class="bg-dark-900 border border-dark-800 rounded-2xl p-5 text-center">
        <div class="text-3xl mb-1">👁</div>
        <div class="text-2xl font-bold text-amber-400"><%= stats.totalViews %></div>
        <div class="text-xs text-gray-500">مشاهدات على تجاربك</div>
      </div>
    </div>

    <% if (myStories && myStories.length > 0) { %>
      <h2 class="text-xl font-bold mb-4">آخر تجاربك</h2>
      <div class="space-y-2">
        <% myStories.forEach(s => { %>
          <a href="/story/<%= s.id %>" class="block bg-dark-900 border border-dark-800 rounded-xl p-4 hover:border-brand-500/30 transition">
            <div class="flex items-center justify-between">
              <span class="font-medium"><%= s.hide_name ? '👤 مجهول' : s.name %></span>
              <div class="text-xs text-gray-500">👁 <%= s.views %> · <%= new Date(s.created_at).toLocaleDateString('ar-SA') %></div>
            </div>
          </a>
        <% }) %>
      </div>
    <% } %>
  <% } %>
</div>