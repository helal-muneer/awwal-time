<!-- Hero -->
<div class="text-center py-8 md:py-12 fade-up">
  <h1 class="text-4xl md:text-5xl font-extrabold mb-3">
    <span style="color: var(--primary)">أول مرّة</span>
  </h1>
  <p class="text-gray-400 mb-6 max-w-md mx-auto text-sm">كل شخص عنده تجربة مرّ بها لأول مرة — شارك وتعلم من تجارب الآخرين</p>
  <div class="flex justify-center gap-6 text-sm">
    <div class="text-center">
      <div class="text-xl font-bold text-brand-400"><%= totalStories %></div>
      <div class="text-gray-500 text-xs">تجربة</div>
    </div>
    <div class="w-px bg-dark-700"></div>
    <div class="text-center">
      <div class="text-xl font-bold text-yellow-400"><%= totalViews %></div>
      <div class="text-gray-500 text-xs">قراءة</div>
    </div>
    <div class="w-px bg-dark-700"></div>
    <div class="text-center">
      <div class="text-xl font-bold text-green-400"><%= totalReactions %></div>
      <div class="text-gray-500 text-xs">تفاعل</div>
    </div>
  </div>
</div>

<% if (typeof features !== 'undefined' && features.show_weekly_question && weeklyQuestion) { %>
<div class="max-w-2xl mx-auto mb-6 fade-up">
  <div class="relative rounded-2xl p-5 bg-dark-800/60 border border-dark-700/30">
    <div class="absolute top-3 left-3 text-xs bg-brand-600 text-white px-3 py-1 rounded-full font-bold">💡 سؤال الأسبوع</div>
    <p class="text-lg font-bold text-center mt-3 text-gray-100"><%= weeklyQuestion %></p>
  </div>
</div>
<% } %>

<!-- Categories (if enabled) -->
<% if (typeof features !== 'undefined' && features.show_categories) { %>
<div class="fade-up mb-6">
  <div class="flex flex-wrap justify-center gap-2">
    <a href="/?sort=<%= sort %>&q=<%= search %>" class="px-4 py-2 rounded-full text-sm font-semibold transition <%= !category ? 'bg-brand-600 text-white' : 'bg-dark-800/60 text-gray-400 border border-dark-700/40 hover:text-gray-300' %>">🌟 الكل</a>
    <% categories.forEach(function(c) { %>
      <a href="/?category=<%= encodeURIComponent(c.name) %>&sort=<%= sort %>&q=<%= search %>" class="px-4 py-2 rounded-full text-sm font-semibold transition <%= category === c.name ? 'bg-brand-600 text-white' : 'bg-dark-800/60 text-gray-400 border border-dark-700/40 hover:text-gray-300' %>">
        <%= c.icon %> <%= c.name %>
      </a>
    <% }); %>
  </div>
</div>
<% } %>

<!-- Sort -->
<% if (stories.length > 0) { %>
<div class="fade-up flex items-center justify-between gap-3 mb-5">
  <div class="flex gap-2">
    <% var sorts = [{v:'latest',l:'الأحدث'},{v:'views',l:'الأكثر مشاهدة'},{v:'reacts',l:'الأكثر تفاعلاً'},{v:'random',l:'عشوائي'}]; %>
    <% sorts.forEach(function(s) { %>
      <a href="/?sort=<%= s.v %>&category=<%= encodeURIComponent(category) %>&q=<%= search %>" class="px-3 py-1.5 rounded-lg text-xs font-semibold transition <%= sort === s.v ? 'bg-dark-700 text-white' : 'text-gray-500 hover:text-gray-300' %>"><%= s.l %></a>
    <% }); %>
  </div>
  <% if (category || search) { %>
    <a href="/" class="text-xs text-brand-400">✕ مسح</a>
  <% } %>
</div>
<% } %>

<!-- Stories Feed -->
<% if (stories.length === 0) { %>
<div class="text-center py-16 text-gray-500 fade-up">
  <div class="text-5xl mb-4">📝</div>
  <p class="text-lg mb-2"><%= search ? 'لا توجد نتائج' : 'لا توجد تجارب بعد' %></p>
  <p class="text-sm text-gray-600 mb-6"><%= search ? 'جرّب كلمات بحث مختلفة' : 'كن أول من يشارك تجربته!' %></p>
  <button onclick="openSubmitModal()" class="bg-brand-600 hover:bg-brand-700 px-8 py-3 rounded-full font-bold transition-all" style="color:#fff !important">✍️ شارك الآن</button>
</div>
<% } else { %>
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" id="storiesGrid">
  <% stories.forEach(function(s, idx) { %>
  <%
    var doneItems = (s.done_regrets || '').split('|||').filter(Boolean);
    var notDoneItems = (s.notdone_regrets || '').split('|||').filter(Boolean);
    var showSeparate = typeof features !== 'undefined' && features.show_separate_regrets;
    var displayText = '';
    if (s.comment) { displayText = s.comment; }
    else if (!showSeparate) {
      var parts = [];
      doneItems.forEach(function(d) { parts.push('😔 ' + d); });
      notDoneItems.forEach(function(d) { parts.push('✨ ' + d); });
      displayText = parts.join('\n');
    }
  %>
  <a href="/story/<%= s.id %>" class="story-card bg-dark-800/40 border border-dark-700/30 rounded-2xl p-5 fade-up flex flex-col hover:border-brand-500/30 transition group">
    <!-- Text (prominent) -->
    <% if (displayText) { %>
      <p class="text-gray-200 text-base leading-relaxed flex-1 whitespace-pre-line"><%= displayText.length > 200 ? displayText.substring(0, 200) + '...' : displayText %></p>
    <% } %>

    <% if (showSeparate && doneItems.length) { %>
    <div class="mt-2 flex flex-wrap gap-1">
      <% doneItems.slice(0,2).forEach(function(d) { %>
        <span class="regret-tag bg-brand-900/25 text-brand-300 border border-brand-800/20 text-xs"><%= d %></span>
      <% }); %>
    </div>
    <% } %>
    <% if (showSeparate && notDoneItems.length) { %>
    <div class="mt-1 flex flex-wrap gap-1">
      <% notDoneItems.slice(0,2).forEach(function(d) { %>
        <span class="regret-tag bg-yellow-900/15 text-yellow-300 border border-yellow-800/15 text-xs"><%= d %></span>
      <% }); %>
    </div>
    <% } %>

    <!-- Footer: name, reactions, comments -->
    <div class="flex items-center justify-between mt-4 pt-3 border-t border-dark-700/30">
      <div class="flex items-center gap-2">
        <span class="text-xs text-gray-500"><%= s.hide_name ? '👤 مجهول' : s.name %></span>
        <span class="text-xs text-gray-600">· <%= new Date(s.created_at).toLocaleDateString('ar-SA') %></span>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-xs text-gray-500">🫂 <%= s.reactions && s.reactions.relatable || 0 %></span>
        <span class="text-xs text-gray-500">❤️ <%= s.reactions && s.reactions.sympathy || 0 %></span>
        <span class="text-xs text-gray-500">💪 <%= s.reactions && s.reactions.motivated || 0 %></span>
        <span class="text-xs text-gray-500">💬 <%= s.comment_count || 0 %></span>
      </div>
    </div>
  </a>
  <% }); %>
</div>
<% } %>

<!-- Load More -->
<% if (hasMore) { %>
<div class="text-center mt-8 fade-up">
  <a href="/?page=<%= currentPage + 1 %>&sort=<%= sort %>&category=<%= encodeURIComponent(category) %>&q=<%= search %>" class="bg-dark-800/60 hover:bg-dark-700 border border-dark-700/40 px-8 py-3 rounded-full font-bold transition-all inline-flex items-center gap-2">
    تحميل المزيد ⬇️
  </a>
</div>
<% } %>

<!-- FAB -->
<button onclick="openSubmitModal()" id="fabBtn" class="fixed bottom-6 left-6 z-40 w-14 h-14 bg-brand-600 hover:bg-brand-700 rounded-full shadow-lg shadow-brand-600/25 flex items-center justify-center text-2xl transition-all hover:scale-110" style="color:#fff !important" title="شارك تجربتك">✍️</button>

<!-- Submit Modal -->
<div id="submitModal" class="hidden fixed inset-0 z-50 flex items-end sm:items-center justify-center">
  <div class="absolute inset-0 bg-black/60" onclick="closeSubmitModal()"></div>
  <div class="relative bg-dark-900 border border-dark-700 rounded-t-3xl sm:rounded-2xl w-full max-w-md max-h-[85vh] overflow-y-auto p-5 sm:p-6 animate-slide-up">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-bold">شارك تجربتك ✍️</h2>
      <button onclick="closeSubmitModal()" class="text-gray-500 hover:text-gray-300 text-xl leading-none w-8 h-8 flex items-center justify-center">✕</button>
    </div>

    <form id="modalSubmitForm" class="space-y-3">
      <textarea name="simple_text" id="modalText" rows="5" required placeholder="اكتب تجربتك هنا..." class="w-full bg-dark-800 border border-dark-700 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-brand-500 transition resize-none"></textarea>
      <input type="text" name="name" id="modalName" required placeholder="الاسم *" class="w-full bg-dark-800 border border-dark-700 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-brand-500 transition">
      <input type="email" name="email" id="modalEmail" required placeholder="البريد الإلكتروني *" class="w-full bg-dark-800 border border-dark-700 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-brand-500 transition">
      <label class="flex items-center gap-2 cursor-pointer py-1">
        <input type="checkbox" name="hide_name" value="1" class="accent-brand-500 w-4 h-4">
        <span class="text-sm text-gray-400">إخفاء هويتي 👤</span>
      </label>

      <% if (typeof features !== 'undefined' && features.show_advanced_submit) { %>
      <button type="button" onclick="document.getElementById('advancedSection').classList.toggle('hidden');this.querySelector('span').textContent = document.getElementById('advancedSection').classList.contains('hidden') ? '▼' : '▲'" class="text-sm text-brand-400 hover:text-brand-300 transition py-1">
        خيارات إضافية <span>▼</span>
      </button>
      <div id="advancedSection" class="hidden space-y-3 pt-3 border-t border-dark-700/30">
        <div>
          <label class="block text-xs text-gray-500 mb-1">التصنيف</label>
          <div class="flex flex-wrap gap-2">
            <% (categories || []).forEach(function(c) { %>
              <label class="cursor-pointer">
                <input type="radio" name="category" value="<%= c.name %>" class="hidden peer" <%= c.name === 'شخصي' ? 'checked' : '' %>>
                <div class="peer-checked:cat-active bg-dark-700/50 border border-dark-600/40 rounded-lg px-3 py-1.5 text-xs text-center transition hover:bg-dark-700">
                  <%= c.icon %> <%= c.name %>
                </div>
              </label>
            <% }); %>
          </div>
        </div>
        <div>
          <label class="block text-xs text-gray-500 mb-1">😔 ندم عليها</label>
          <input type="text" name="done1" placeholder="مثال: تأخرت في الدراسة" class="w-full bg-dark-800 border border-dark-700 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-brand-500 transition">
        </div>
        <div>
          <label class="block text-xs text-gray-500 mb-1">✨ تمنيت لو فعلتها</label>
          <input type="text" name="notdone1" placeholder="مثال: لو سافرت أكثر" class="w-full bg-dark-800 border border-dark-700 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-brand-500 transition">
        </div>
      </div>
      <% } %>

      <input type="hidden" name="simple_mode" value="1">
      <button type="submit" id="modalSubmitBtn" class="w-full bg-brand-600 hover:bg-brand-700 py-3 rounded-xl font-bold transition-all" style="color:#fff !important">🚀 إرسال</button>
    </form>
  </div>
</div>

<style>
  @keyframes slide-up {
    from { transform: translateY(100%); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
  .animate-slide-up { animation: slide-up 0.3s cubic-bezier(0.16, 1, 0.3, 1); }
  @media (min-width: 640px) {
    .animate-slide-up { animation: none; }
  }
</style>

<script>
function openSubmitModal() {
  document.getElementById('submitModal').classList.remove('hidden');
  document.body.style.overflow = 'hidden';
  setTimeout(() => document.getElementById('modalText').focus(), 100);
}
function closeSubmitModal() {
  document.getElementById('submitModal').classList.add('hidden');
  document.body.style.overflow = '';
}

// Modal form submit via AJAX
document.getElementById('modalSubmitForm').addEventListener('submit', function(e) {
  e.preventDefault();
  const form = this;
  const name = form.name.value.trim();
  const text = form.simple_text.value.trim();
  if (!name || !text) { showToast('يرجى ملء الحقول المطلوبة', 'error'); return; }

  const btn = document.getElementById('modalSubmitBtn');
  btn.disabled = true;
  btn.textContent = '⏳ جاري الإرسال...';

  // If advanced fields are visible and filled, switch to advanced mode
  const done1 = form.done1 ? form.done1.value.trim() : '';
  const notdone1 = form.notdone1 ? form.notdone1.value.trim() : '';
  const isAdvanced = done1 || notdone1;

  const formData = new FormData(form);
  if (isAdvanced) {
    formData.set('simple_mode', '0');
    formData.set('comment', text);
  }

  fetch('/submit', {
    method: 'POST',
    headers: { 'X-Requested-With': 'XMLHttpRequest', 'Accept': 'application/json' },
    body: formData
  })
  .then(async r => {
    const text = await r.text();
    try { return JSON.parse(text); } catch(e) { return { ok: false, error: text.substring(0, 100) }; }
  })
  .then(data => {
    if (data.ok) {
      closeSubmitModal();
      form.reset();
      showToast('تم نشر تجربتك بنجاح! 🎉', 'success');
    } else {
      showToast(data.error || 'حدث خطأ، حاول مرة أخرى', 'error');
    }
  })
  .catch(() => {
    showToast('خطأ في الاتصال، حاول مرة أخرى', 'error');
  })
  .finally(() => {
    btn.disabled = false;
    btn.textContent = '🚀 إرسال';
  });
});

// Favorites
function getFavorites(){try{return JSON.parse(localStorage.getItem('awwal_favorites')||'[]')}catch{return[]}}
function isFavorite(id){return getFavorites().includes(Number(id))}
function toggleFavorite(id){let f=getFavorites();id=Number(id);if(f.includes(id)){f=f.filter(x=>x!==id);showToast('تم الإزالة من المفضلة','info')}else{f.push(id);showToast('تم الإضافة للمفضلة ❤️','success')}localStorage.setItem('awwal_favorites',JSON.stringify(f));updateFavButtons()}
function updateFavButtons(){document.querySelectorAll('.fav-btn').forEach(b=>{b.textContent=isFavorite(b.dataset.id)?'❤️':'🤍'})}
updateFavButtons();

// Category radio active state
document.querySelectorAll('.peer-checked\\:cat-active').forEach(el => {
  const input = el.previousElementSibling;
  if (input && input.checked) {
    el.style.background = 'color-mix(in srgb, var(--primary) 20%, transparent)';
    el.style.borderColor = 'color-mix(in srgb, var(--primary) 50%, transparent)';
  }
});
</script>
