<h2 class="text-2xl font-bold mb-6">💾 النسخ الاحتياطية</h2>

<div class="flex gap-3 mb-6">
  <a href="/admin/backup" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-full font-bold text-sm transition">💾 إنشاء نسخة احتياطية</a>
</div>

<div class="bg-white rounded-xl p-5 shadow-sm border">
  <h3 class="font-bold mb-4">📁 النسخ السابقة</h3>
  <% if (files.length === 0) { %>
    <p class="text-gray-400 text-sm">لا توجد نسخ احتياطية</p>
  <% } else { %>
    <div class="space-y-2">
      <% files.forEach(f => { %>
        <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
          <div>
            <span class="text-sm font-mono" dir="ltr"><%= f %></span>
          </div>
          <div class="flex gap-2">
            <a href="/admin/backup/download/<%= f %>" class="bg-green-600 hover:bg-green-700 text-white px-3 py-1 rounded-full text-xs">⬇️ تحميل</a>
            <form method="POST" action="/admin/backup/delete/<%= f %>" onsubmit="return confirm('هل أنت متأكد؟')">
              <button type="submit" class="bg-red-600 hover:bg-red-700 text-white px-3 py-1 rounded-full text-xs">🗑️ حذف</button>
            </form>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>

<div class="mt-6 bg-yellow-50 border border-yellow-200 rounded-xl p-4 text-sm">
  <h4 class="font-bold text-yellow-700 mb-2">💡 اقتراح: نسخ احتياطي تلقائي</h4>
  <p class="text-yellow-600" dir="ltr">يمكنك إضافة cron job للنسخ التلقائي اليومي:</p>
  <code class="block mt-2 bg-white p-2 rounded text-xs" dir="ltr">curl -s http://localhost:3000/admin/backup -b "admin_token=$(cat /path/to/token)"</code>
</div>
