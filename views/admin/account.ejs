<h2 class="text-2xl font-bold mb-6">👤 إدارة الحساب</h2>

<% if (typeof error !== 'undefined' && error) { %>
  <div class="bg-red-50 text-red-600 text-sm rounded-xl p-3 mb-4"><%= error %></div>
<% } %>
<% if (typeof success !== 'undefined' && success) { %>
  <div class="bg-green-50 text-green-600 text-sm rounded-xl p-3 mb-4"><%= success %></div>
<% } %>

<div class="max-w-md">
  <div class="bg-white rounded-xl p-5 shadow-sm border mb-6">
    <h3 class="font-bold mb-3">🔒 تغيير كلمة المرور</h3>
    <form method="POST" action="/admin/account/password" class="space-y-4">
      <div>
        <label class="block text-sm font-bold mb-1">كلمة المرور الحالية</label>
        <input type="password" name="current_password" required class="w-full border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-orange-500">
      </div>
      <div>
        <label class="block text-sm font-bold mb-1">كلمة المرور الجديدة</label>
        <input type="password" name="new_password" required minlength="6" class="w-full border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-orange-500">
      </div>
      <div>
        <label class="block text-sm font-bold mb-1">تأكيد كلمة المرور الجديدة</label>
        <input type="password" name="confirm_password" required class="w-full border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-orange-500">
      </div>
      <button type="submit" class="bg-orange-600 hover:bg-orange-700 text-white px-6 py-2 rounded-full font-bold transition">🔒 تغيير</button>
    </form>
  </div>

  <div class="bg-white rounded-xl p-5 shadow-sm border">
    <h3 class="font-bold mb-3">📋 معلومات الحساب</h3>
    <div class="text-sm text-gray-600 space-y-2">
      <% admins.forEach(a => { %>
        <div class="flex justify-between items-center py-1 border-b">
          <span><%= a.username %></span>
          <span class="text-xs text-gray-400"><%= new Date(a.created_at).toLocaleDateString('ar-SA') %></span>
        </div>
      <% }) %>
    </div>
  </div>
</div>
