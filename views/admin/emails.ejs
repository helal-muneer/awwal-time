<div class="flex items-center justify-between mb-4">
  <h2 class="text-2xl font-bold">📧 الإيميلات المسجلة (<%= emails.length %>)</h2>
  <a href="/admin/export?type=emails&format=csv" class="text-sm bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-full transition">📥 تصدير CSV</a>
</div>

<% if (emails.length === 0) { %>
  <div class="text-center py-16 text-gray-400 bg-white rounded-xl border">
    <div class="text-5xl mb-4">📭</div>
    <p>لا توجد إيميلات</p>
  </div>
<% } else { %>
  <div class="bg-white rounded-xl shadow-sm border overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-right">#</th>
          <th class="px-4 py-3 text-right">الإيميل</th>
          <th class="px-4 py-3 text-right">المصدر</th>
          <th class="px-4 py-3 text-right">التاريخ</th>
          <th class="px-4 py-3 text-right">إجراء</th>
        </tr>
      </thead>
      <tbody>
        <% emails.forEach((e, i) => { %>
          <tr class="border-t hover:bg-gray-50">
            <td class="px-4 py-2 text-gray-500"><%= i+1 %></td>
            <td class="px-4 py-2" dir="ltr"><%= e.email %></td>
            <td class="px-4 py-2"><span class="text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full"><%= e.source %></span></td>
            <td class="px-4 py-2 text-gray-500 text-xs"><%= new Date(e.created_at).toLocaleString('ar-SA') %></td>
            <td class="px-4 py-2">
              <form action="/admin/emails/delete/<%= e.id %>" method="POST" onsubmit="return confirm('حذف هذا الإيميل؟')">
                <button class="text-xs text-red-500 hover:text-red-700">🗑</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>
