<div class="max-w-4xl">
  <h1 class="text-2xl font-bold mb-6">📬 الرسائل <span class="text-sm font-normal text-gray-500">(<%= unread %> غير مقروءة)</span></h1>

  <% if (messages.length === 0) { %>
    <div class="bg-white rounded-xl p-8 text-center text-gray-500">
      <div class="text-4xl mb-3">📬</div>
      <p>لا توجد رسائل بعد</p>
    </div>
  <% } else { %>
    <div class="space-y-3">
      <% messages.forEach(function(m) { %>
        <div class="bg-white rounded-xl shadow p-4 <%= !m.is_read ? 'border-r-4 border-blue-500' : '' %>">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1">
                <span class="font-bold text-sm"><%= m.name %></span>
                <span class="text-xs text-gray-500">&lt;<%= m.email %>&gt;</span>
                <% if (!m.is_read) { %><span class="bg-blue-100 text-blue-700 text-xs px-2 py-0.5 rounded-full">جديدة</span><% } %>
              </div>
              <% if (m.subject) { %><div class="text-sm font-semibold text-gray-700 mb-1"><%= m.subject %></div><% } %>
              <p class="text-sm text-gray-600"><%= m.message %></p>
              <div class="text-xs text-gray-400 mt-2"><%= new Date(m.created_at).toLocaleDateString('ar-SA', {year:'numeric',month:'long',day:'numeric',hour:'2-digit',minute:'2-digit'}) %></div>
            </div>
            <div class="flex gap-1 flex-shrink-0">
              <% if (!m.is_read) { %>
                <form method="POST" action="/admin/message/<%= m.id %>/read" class="inline">
                  <button class="px-2 py-1 rounded text-xs bg-green-100 text-green-700 hover:bg-green-200 transition">قراءة</button>
                </form>
              <% } %>
              <form method="POST" action="/admin/message/<%= m.id %>/delete" class="inline" onsubmit="return confirm('هل أنت متأكد؟')">
                <button class="px-2 py-1 rounded text-xs bg-red-100 text-red-700 hover:bg-red-200 transition">حذف</button>
              </form>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>
