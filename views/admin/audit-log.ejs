<div class="max-w-6xl">
  <h2 class="text-2xl font-bold mb-6">🔒 سجل المراجعة</h2>

  <!-- Filters -->
  <form method="GET" class="flex gap-3 mb-6 flex-wrap">
    <input type="text" name="action" value="<%= actionFilter %>" placeholder="بحث في الإجراء..." class="border rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-orange-400 focus:outline-none">
    <input type="text" name="user" value="<%= userFilter %>" placeholder="بحث في المستخدم..." class="border rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-orange-400 focus:outline-none">
    <button type="submit" class="bg-orange-500 text-white px-4 py-2 rounded-lg text-sm hover:bg-orange-600 transition">بحث</button>
    <a href="/admin/audit-log" class="bg-gray-200 text-gray-700 px-4 py-2 rounded-lg text-sm hover:bg-gray-300 transition">مسح الفلاتر</a>
  </form>

  <% if (logs.length === 0) { %>
    <div class="bg-white rounded-xl p-8 text-center text-gray-500">
      <div class="text-4xl mb-3">🔒</div>
      <p>لا توجد سجلات مراجعة</p>
    </div>
  <% } else { %>
    <div class="bg-white rounded-xl shadow overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-gray-50">
          <tr>
            <th class="text-right p-3 font-semibold">الإجراء</th>
            <th class="text-right p-3 font-semibold">المستخدم</th>
            <th class="text-right p-3 font-semibold">التفاصيل</th>
            <th class="text-right p-3 font-semibold">IP</th>
            <th class="text-right p-3 font-semibold">التاريخ</th>
          </tr>
        </thead>
        <tbody class="divide-y">
          <% logs.forEach(function(log) { %>
            <tr class="hover:bg-gray-50">
              <td class="p-3">
                <span class="px-2 py-1 rounded-full text-xs font-medium
                  <%= log.action.includes('دخول') ? 'bg-blue-100 text-blue-700' : '' %>
                  <%= log.action.includes('خروج') ? 'bg-gray-100 text-gray-700' : '' %>
                  <%= log.action.includes('موافقة') ? 'bg-green-100 text-green-700' : '' %>
                  <%= log.action.includes('حذف') ? 'bg-red-100 text-red-700' : '' %>
                  <%= log.action.includes('تعديل') || log.action.includes('تحديث') ? 'bg-yellow-100 text-yellow-700' : '' %>
                  <%= log.action.includes('نسخ') ? 'bg-purple-100 text-purple-700' : '' %>
                  <%= log.action.includes('رد') ? 'bg-indigo-100 text-indigo-700' : '' %>
                  <%= (!log.action.includes('دخول') && !log.action.includes('خروج') && !log.action.includes('موافقة') && !log.action.includes('حذف') && !log.action.includes('تعديل') && !log.action.includes('تحديث') && !log.action.includes('نسخ') && !log.action.includes('رد')) ? 'bg-orange-100 text-orange-700' : '' %>
                "><%= log.action %></span>
              </td>
              <td class="p-3 font-mono text-xs"><%= log.user %></td>
              <td class="p-3 text-xs text-gray-600 max-w-xs truncate"><%= log.details || '-' %></td>
              <td class="p-3 font-mono text-xs text-gray-500"><%= log.ip || '-' %></td>
              <td class="p-3 text-xs text-gray-500 whitespace-nowrap"><%= new Date(log.created_at).toLocaleString('ar-SA') %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <% if (totalPages > 1) { %>
    <div class="flex justify-center gap-2 mt-6">
      <% for (let i = 1; i <= totalPages; i++) { %>
        <a href="?page=<%= i %>&action=<%= actionFilter %>&user=<%= userFilter %>" class="px-3 py-1 rounded text-sm <%= i === currentPage ? 'bg-orange-500 text-white' : 'bg-white text-gray-700 hover:bg-gray-100' %> transition"><%= i %></a>
      <% } %>
    </div>
    <% } %>
  <% } %>
</div>
