<div class="max-w-4xl mx-auto fade-up">
  <div class="text-center mb-8">
    <h1 class="text-3xl font-bold mb-2">🔄 مقارنة التجارب</h1>
    <p class="text-gray-400">اكتشف كيف تختلف تجارب الناس</p>
  </div>

  <div class="grid md:grid-cols-2 gap-6 mb-8">
    <% stories.forEach(function(s, idx) { %>
    <div class="bg-dark-800/40 border border-dark-700/30 rounded-2xl p-6">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-12 h-12 bg-dark-700/60 rounded-full flex items-center justify-center text-2xl"><%= s.hide_name ? '👤' : '😊' %></div>
        <div>
          <h2 class="font-bold text-lg">تجربة <%= s.hide_name ? 'مجهول' : s.name %></h2>
          <div class="text-xs text-gray-500 flex gap-2">
            <span><%= s.category %></span>
            <span>·</span>
            <span><%= new Date(s.created_at).toLocaleDateString('ar-SA') %></span>
          </div>
        </div>
      </div>

      <% if (s.doneItems.length) { %>
      <div class="mb-4">
        <h3 class="text-sm font-bold text-brand-400 mb-2">😔 ندم عليها</h3>
        <div class="space-y-2">
          <% s.doneItems.forEach(function(item) { %>
          <div class="bg-brand-900/10 border border-brand-800/15 rounded-lg p-2.5 text-sm text-gray-300">• <%= item %></div>
          <% }); %>
        </div>
      </div>
      <% } %>

      <% if (s.notDoneItems.length) { %>
      <div class="mb-4">
        <h3 class="text-sm font-bold text-yellow-400 mb-2">✨ تمنى لو فعلها</h3>
        <div class="space-y-2">
          <% s.notDoneItems.forEach(function(item) { %>
          <div class="bg-yellow-900/10 border border-yellow-800/15 rounded-lg p-2.5 text-sm text-gray-300">• <%= item %></div>
          <% }); %>
        </div>
      </div>
      <% } %>

      <div class="flex gap-4 text-xs text-gray-500 pt-3 border-t border-dark-700/30">
        <span>👁 <%= s.views %></span>
        <span>🫂 <%= s.reactions.relatable || 0 %></span>
        <span>❤️ <%= s.reactions.sympathy || 0 %></span>
        <span>💪 <%= s.reactions.motivated || 0 %></span>
        <span>💬 <%= s.commentCount %></span>
      </div>

      <a href="/story/<%= s.id %>" class="mt-3 block text-center bg-dark-700 hover:bg-dark-600 py-2 rounded-xl text-sm font-bold transition">قراءة كاملة ←</a>
    </div>
    <% }); %>
  </div>

  <div class="text-center">
    <a href="/compare" class="inline-flex items-center gap-2 bg-brand-600 hover:bg-brand-700 px-8 py-3 rounded-full font-bold transition" style="color:#fff !important">🔄 تجربة جديدة</a>
  </div>
</div>
