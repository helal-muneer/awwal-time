<div class="max-w-2xl mx-auto fade-up">
  <div class="text-center mb-8">
    <div class="text-4xl mb-3">🔍</div>
    <h1 class="text-3xl font-bold mb-2">البحث المتقدم</h1>
    <p class="text-gray-400 text-sm">ابحث في تجارب الناس</p>
  </div>

  <!-- Search Form -->
  <form action="/search" method="GET" class="bg-dark-800/60 border border-dark-700/40 rounded-2xl p-6 mb-6">
    <div class="flex gap-3 mb-4">
      <input type="text" name="q" value="<%= q %>" placeholder="ابحث عن تجربة..." class="flex-1 bg-dark-700 border border-dark-600 rounded-xl px-4 py-3 focus:outline-none focus:border-brand-500 transition" autofocus>
      <button type="submit" class="bg-brand-600 hover:bg-brand-700 px-6 py-3 rounded-xl font-bold text-sm transition">بحث</button>
    </div>
    <div class="flex flex-wrap gap-3">
      <select name="category" class="bg-dark-700 border border-dark-600 rounded-xl px-4 py-2 text-sm focus:outline-none focus:border-brand-500 transition">
        <option value="">كل التصنيفات</option>
        <% (categories || []).forEach(function(c) { %>
          <option value="<%= c.name %>" <%= category === c.name ? 'selected' : '' %>><%= c.icon %> <%= c.name %></option>
        <% }); %>
      </select>
      <select name="sort" class="bg-dark-700 border border-dark-600 rounded-xl px-4 py-2 text-sm focus:outline-none focus:border-brand-500 transition">
        <option value="latest" <%= sort === 'latest' ? 'selected' : '' %>>الأحدث</option>
        <option value="oldest" <%= sort === 'oldest' ? 'selected' : '' %>>الأقدم</option>
        <option value="views" <%= sort === 'views' ? 'selected' : '' %>>الأكثر مشاهدة</option>
      </select>
      <% if (q || category) { %>
        <a href="/search" class="text-sm text-gray-400 hover:text-gray-300 transition flex items-center gap-1">✕ مسح الفلاتر</a>
      <% } %>
    </div>
  </form>

  <!-- Results -->
  <div class="mb-4 text-sm text-gray-400">
    <% if (q) { %>
      <span>نتائج البحث عن "<strong class="text-gray-200"><%= q %></strong>"</span>
    <% } %>
    <span class="mr-2">• <strong class="text-brand-400"><%= totalCount %></strong> نتيجة</span>
  </div>

  <% if (stories.length === 0) { %>
    <div class="text-center py-16">
      <div class="text-5xl mb-4">📭</div>
      <p class="text-gray-400 text-lg">لا توجد نتائج</p>
      <p class="text-gray-500 text-sm mt-2">جرّب كلمات بحث مختلفة أو غيّر الفلاتر</p>
      <a href="/submit" style="color:#fff !important" class="inline-block mt-4 bg-brand-600 hover:bg-brand-700 px-6 py-2.5 rounded-full font-bold text-sm transition">✍️ شارك تجربتك</a>
    </div>
  <% } %>

  <div class="space-y-4">
    <% stories.forEach(function(s) {
      var rDone = (s.done_regrets || '').split('|||').filter(Boolean);
      var rNotDone = (s.notdone_regrets || '').split('|||').filter(Boolean);
    %>
    <a href="/story/<%= s.id %>" class="story-card bg-dark-800/40 border border-dark-700/30 rounded-2xl p-5 block">
      <div class="flex items-center gap-3 mb-3">
        <div class="w-12 h-12 bg-dark-700/60 rounded-full flex items-center justify-center text-2xl flex-shrink-0">
          <%= s.hide_name ? '👤' : '😊' %>
        </div>
        <div class="flex-1 min-w-0">
          <div class="font-bold text-lg truncate"><%= highlight(s.hide_name ? 'مجهول' : s.name, q) %></div>
          <div class="flex items-center gap-2 text-xs text-gray-500">
            <span><%= new Date(s.created_at).toLocaleDateString('ar-SA') %></span>
            <% if (s.category) { %><span>•</span><span class="text-brand-400"><%= s.category %></span><% } %>
          </div>
        </div>
        <% if (s.image_url) { %>
          <img src="/<%= s.image_url %>" class="w-16 h-16 rounded-lg object-cover flex-shrink-0 lazy-img" loading="lazy" onload="this.classList.add('loaded')">
        <% } %>
      </div>
      <% if (rDone.length) { %>
        <div class="flex flex-wrap gap-1 mb-2">
          <% rDone.slice(0,3).forEach(function(d){ %>
            <span class="regret-tag bg-brand-900/25 text-brand-300 border border-brand-800/20"><%= highlight(d, q) %></span>
          <% }); %>
          <% if (rDone.length > 3) { %><span class="text-xs text-gray-500">+<%= rDone.length - 3 %></span><% } %>
        </div>
      <% } %>
      <% if (rNotDone.length) { %>
        <div class="flex flex-wrap gap-1 mb-2">
          <% rNotDone.slice(0,3).forEach(function(d){ %>
            <span class="regret-tag bg-yellow-900/20 text-yellow-300 border border-yellow-800/15"><%= highlight(d, q) %></span>
          <% }); %>
          <% if (rNotDone.length > 3) { %><span class="text-xs text-gray-500">+<%= rNotDone.length - 3 %></span><% } %>
        </div>
      <% } %>
      <div class="flex items-center gap-4 text-xs text-gray-500 mt-2">
        <span>👁 <%= s.views %></span>
        <% if (s.total_reacts) { %><span>❤️ <%= s.total_reacts %></span><% } %>
      </div>
    </a>
    <% }); %>
  </div>

  <!-- Pagination -->
  <% if (totalPages > 1) { %>
  <div class="flex justify-center gap-2 mt-8">
    <% if (currentPage > 1) { %>
      <a href="/search?q=<%= encodeURIComponent(q) %>&category=<%= category %>&sort=<%= sort %>&page=<%= currentPage - 1 %>" class="bg-dark-800/60 border border-dark-700/40 px-4 py-2 rounded-xl text-sm hover:bg-dark-700/60 transition">السابق</a>
    <% } %>
    <span class="bg-dark-700/50 border border-dark-600/30 px-4 py-2 rounded-xl text-sm"><%= currentPage %> / <%= totalPages %></span>
    <% if (currentPage < totalPages) { %>
      <a href="/search?q=<%= encodeURIComponent(q) %>&category=<%= category %>&sort=<%= sort %>&page=<%= currentPage + 1 %>" class="bg-dark-800/60 border border-dark-700/40 px-4 py-2 rounded-xl text-sm hover:bg-dark-700/60 transition">التالي</a>
    <% } %>
  </div>
  <% } %>
</div>
