<div class="text-center py-20">
  <div class="fade-up">
    <div class="text-8xl mb-6 animate-bounce">🔄</div>
    <h1 class="text-3xl font-bold mb-3">أووبس! الصفحة غير موجودة</h1>
    <p class="text-gray-400 mb-8">يبدو إنك ضعت طريقك... لا تقلق، هذا يحصل!</p>
    <a href="/" class="bg-brand-600 hover:bg-brand-700 px-6 py-3 rounded-full font-bold transition inline-flex items-center gap-2" style="color:#fff !important">🏠 العودة للرئيسية</a>
  </div>

  <% if (typeof popular !== 'undefined' && popular.length > 0) { %>
  <div class="mt-16 fade-up stagger-1">
    <h2 class="text-lg font-bold mb-6">🔥 تجارب شائحة</h2>
    <div class="grid md:grid-cols-2 gap-3 max-w-2xl mx-auto text-right">
      <% popular.forEach(function(s) { %>
        <a href="/story/<%= s.id %>" class="story-card bg-dark-800/40 border border-dark-700/30 rounded-xl p-4 block">
          <div class="font-bold text-sm truncate"><%= s.hide_name ? 'مجهول' : s.name %></div>
          <div class="text-xs text-gray-500">👁 <%= s.views %> مشاهدة</div>
        </a>
      <% }); %>
    </div>
  </div>
  <% } %>
</div>
