<div class="max-w-2xl mx-auto fade-up">
  <div class="text-center mb-8">
    <div class="text-4xl mb-3">✍️</div>
    <h1 class="text-3xl font-bold mb-2">شارك تجربتك</h1>
    <p class="text-gray-400 text-sm">أخبرنا عن أشياء ندمت عليها وأشياء تمنيت لو فعلتها</p>
  </div>

  <!-- Progress Indicator -->
  <div class="mb-6 bg-dark-800/40 border border-dark-700/30 rounded-xl p-4">
    <div class="flex items-center justify-between mb-2">
      <span class="text-xs text-gray-400">تقدم النموذج</span>
      <span class="text-xs font-bold text-brand-400" id="progressText">0%</span>
    </div>
    <div class="w-full bg-dark-700 rounded-full h-2">
      <div id="progressBar" class="bg-brand-600 h-2 rounded-full transition-all duration-500" style="width: 0%"></div>
    </div>
  </div>

  <% if (typeof error !== 'undefined') { %>
    <div class="bg-red-900/30 border border-red-700/50 text-red-300 rounded-xl p-4 mb-6 text-center text-sm"><%= error %></div>
  <% } %>

  <form action="/submit" method="POST" id="submitForm" class="space-y-6" enctype="multipart/form-data">
    <!-- Category -->
    <div class="bg-dark-800/60 border border-dark-700/40 rounded-2xl p-6">
      <h2 class="font-bold text-lg flex items-center gap-2 mb-4">📂 اختر التصنيف</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
        <% (categories || []).forEach(function(c) { %>
          <label class="cursor-pointer">
            <input type="radio" name="category" value="<%= c.name %>" class="hidden peer" <%= c.name === 'شخصي' ? 'checked' : '' %>>
            <div class="category-option peer-checked:cat-active bg-dark-700/50 border border-dark-600/40 rounded-xl p-3 text-center transition hover:bg-dark-700">
              <div class="text-2xl mb-1"><%= c.icon %></div>
              <div class="text-xs font-semibold"><%= c.name %></div>
            </div>
          </label>
        <% }); %>
      </div>
    </div>

    <!-- Personal Info -->
    <div class="bg-dark-800/60 border border-dark-700/40 rounded-2xl p-6 space-y-4">
      <h2 class="font-bold text-lg flex items-center gap-2">👤 معلوماتك</h2>
      <div>
        <label class="block text-sm text-gray-400 mb-1">الاسم <span class="text-brand-400">*</span></label>
        <input type="text" name="name" id="nameInput" required placeholder="اسمك أو اسم مستعار" class="w-full bg-dark-700 border border-dark-600 rounded-xl px-4 py-3 focus:outline-none focus:border-brand-500 transition">
        <span class="text-xs text-red-400 hidden" id="nameError">يرجى إدخال الاسم</span>
      </div>
      <div>
        <label class="block text-sm text-gray-400 mb-1">البريد الإلكتروني (اختياري)</label>
        <input type="email" name="email" placeholder="بريدك الإلكتروني" class="w-full bg-dark-700 border border-dark-600 rounded-xl px-4 py-3 focus:outline-none focus:border-brand-500 transition">
      </div>
      <label class="flex items-center gap-2 cursor-pointer">
        <input type="checkbox" name="hide_name" value="1" class="accent-brand-500 w-4 h-4">
        <span class="text-sm text-gray-400">أريد البقاء مجهولاً</span>
      </label>
    </div>

    <!-- Done Regrets -->
    <div class="bg-dark-800/60 border border-dark-700/40 rounded-2xl p-6 space-y-4">
      <h2 class="font-bold text-lg flex items-center gap-2">😔 أشياء فعلتها وندمت عليها</h2>
      <p class="text-xs text-gray-500">أضف بند واحد على الأقل</p>
      <div id="doneList" class="space-y-2">
        <div class="flex items-center gap-2">
          <span class="bg-brand-600 text-white w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0 done-num">1</span>
          <input type="text" name="done1" placeholder="مثال: تأخرت في الدراسة" class="flex-1 bg-dark-700 border border-dark-600 rounded-xl px-4 py-3 focus:outline-none focus:border-brand-500 transition text-sm regret-input">
        </div>
      </div>
      <button type="button" onclick="addRegretField('doneList','done','done-num','bg-brand-600')" class="text-sm text-brand-400 hover:text-brand-300 transition flex items-center gap-1">+ إضافة بند آخر</button>
      <span class="text-xs text-red-400 hidden" id="doneError">أضف بند واحد على الأقل</span>
    </div>

    <!-- Not Done Regrets -->
    <div class="bg-dark-800/60 border border-dark-700/40 rounded-2xl p-6 space-y-4">
      <h2 class="font-bold text-lg flex items-center gap-2">✨ أشياء ندمت أنني لم أفعلها</h2>
      <p class="text-xs text-gray-500">أضف بند واحد على الأقل</p>
      <div id="notdoneList" class="space-y-2">
        <div class="flex items-center gap-2">
          <span class="bg-yellow-600 text-white w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0 notdone-num">1</span>
          <input type="text" name="notdone1" placeholder="مثال: لو سافرت أكثر" class="flex-1 bg-dark-700 border border-dark-600 rounded-xl px-4 py-3 focus:outline-none focus:border-brand-500 transition text-sm regret-input">
        </div>
      </div>
      <button type="button" onclick="addRegretField('notdoneList','notdone','notdone-num','bg-yellow-600')" class="text-sm text-yellow-400 hover:text-yellow-300 transition flex items-center gap-1">+ إضافة بند آخر</button>
      <span class="text-xs text-red-400 hidden" id="notdoneError">أضف بند واحد على الأقل</span>
    </div>

    <!-- Image Upload -->
    <div class="bg-dark-800/60 border border-dark-700/40 rounded-2xl p-6">
      <h2 class="font-bold text-lg flex items-center gap-2 mb-3">📷 صورة (اختياري)</h2>
      <p class="text-xs text-gray-500 mb-3">أضف صورة واحدة بحد أقصى 2 ميجا</p>
      <input type="file" name="image" id="imageInput" accept="image/*" class="hidden" onchange="previewImage(this)">
      <label for="imageInput" class="flex flex-col items-center gap-2 cursor-pointer bg-dark-700/50 border-2 border-dashed border-dark-600/40 rounded-xl p-6 hover:border-brand-500/50 transition">
        <span class="text-3xl" id="uploadIcon">📁</span>
        <span class="text-sm text-gray-400" id="uploadText">اضغط لاختيار صورة</span>
      </label>
      <div id="imagePreview" class="mt-3 hidden">
        <img id="previewImg" class="max-h-48 rounded-xl mx-auto">
        <button type="button" onclick="removeImage()" class="text-xs text-red-400 hover:text-red-300 mt-2 block mx-auto">✕ إزالة الصورة</button>
      </div>
    </div>

    <!-- Comment -->
    <div class="bg-dark-800/60 border border-dark-700/40 rounded-2xl p-6">
      <h2 class="font-bold text-lg flex items-center gap-2 mb-3">💬 تعليق إضافي</h2>
      <textarea name="comment" rows="4" placeholder="أي شيء تبي تضيفه..." class="w-full bg-dark-700 border border-dark-600 rounded-xl px-4 py-3 focus:outline-none focus:border-brand-500 transition text-sm resize-none"></textarea>
    </div>

    <button type="submit" class="w-full bg-brand-600 hover:bg-brand-700 py-4 rounded-2xl font-bold text-lg transition">🚀 إرسال تجربتي</button>
  </form>
</div>

<script>
let doneCount = 1, notdoneCount = 1;
function addRegretField(listId, prefix, numClass, bgColor) {
  const list = document.getElementById(listId);
  const isDone = prefix === 'done';
  const count = isDone ? ++doneCount : ++notdoneCount;
  if (count > 10) return showToast('الحد الأقصى 10 بنود', 'error');
  const div = document.createElement('div');
  div.className = 'flex items-center gap-2';
  div.innerHTML = `<span class="${bgColor} text-white w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0 ${numClass}">${count}</span>
    <input type="text" name="${prefix}${count}" placeholder="..." class="flex-1 bg-dark-700 border border-dark-600 rounded-xl px-4 py-3 focus:outline-none focus:border-brand-500 transition text-sm regret-input">
    <button type="button" onclick="this.parentElement.remove()" class="text-gray-500 hover:text-red-400 transition text-lg">✕</button>`;
  list.appendChild(div);
  div.querySelector('input').focus();
}

// Progress tracking
function updateProgress() {
  const name = document.getElementById('nameInput').value.trim();
  const regrets = document.querySelectorAll('.regret-input');
  let filled = 0;
  regrets.forEach(r => { if (r.value.trim()) filled++; });
  let progress = 0;
  if (name) progress += 30;
  if (filled >= 1) progress += 40;
  if (filled >= 2) progress += 15;
  if (document.querySelector('input[name="category"]:checked')) progress += 15;
  progress = Math.min(100, progress);
  document.getElementById('progressBar').style.width = progress + '%';
  document.getElementById('progressText').textContent = progress + '%';
}

document.getElementById('submitForm').addEventListener('input', updateProgress);
document.getElementById('submitForm').addEventListener('change', updateProgress);

// Inline validation
document.getElementById('submitForm').addEventListener('submit', function(e) {
  let valid = true;
  if (!document.getElementById('nameInput').value.trim()) {
    document.getElementById('nameError').classList.remove('hidden');
    valid = false;
  } else { document.getElementById('nameError').classList.add('hidden'); }

  const doneInputs = document.querySelectorAll('#doneList .regret-input');
  const notdoneInputs = document.querySelectorAll('#notdoneList .regret-input');
  const hasDone = Array.from(doneInputs).some(i => i.value.trim());
  const hasNotDone = Array.from(notdoneInputs).some(i => i.value.trim());
  if (!hasDone && !hasNotDone) {
    document.getElementById('doneError').classList.remove('hidden');
    document.getElementById('notdoneError').classList.remove('hidden');
    valid = false;
  } else {
    document.getElementById('doneError').classList.add('hidden');
    document.getElementById('notdoneError').classList.add('hidden');
  }
  if (!valid) { e.preventDefault(); showToast('يرجى ملء الحقول المطلوبة', 'error'); }
});

updateProgress();

// Guided Writing Prompts
const categoryPrompts = {
  'علاقات': { done: 'تأخرت في الاعتراف بمشاعري', notdone: 'خسرت صديق بسبب سوء تفاهم' },
  'دراسة': { done: 'تأخرت في التقديم', notdone: 'ما درست للمحاضرة' },
  'عمل': { done: 'رفضت فرصة عمل', notdone: 'ما طلبت زيادة راتب' },
  'صحة': { done: 'ما تمارست الرياضة', notdone: 'أهملت صحتي النفسية' },
  'سفر': { done: 'ما سافرت لما كان عندي الفرصة', notdone: 'ما جربت شيء جديد في السفر' },
  'مال': { done: 'أنفقت على شيء ما أحتاجه', notdone: 'ما ادخرت' },
  'عائلة': { done: 'ما قضيت وقت كافي مع أهلي', notdone: 'ما قلت كلمة حلوة' },
  'شخصي': { done: 'ما جربت هواية جديدة', notdone: 'ما كسرت روتيني' }
};
function updatePlaceholders(cat) {
  const p = categoryPrompts[cat] || categoryPrompts['شخصي'];
  document.querySelectorAll('#doneList .regret-input').forEach((inp, i) => {
    inp.placeholder = i === 0 ? p.done : '...';
  });
  document.querySelectorAll('#notdoneList .regret-input').forEach((inp, i) => {
    inp.placeholder = i === 0 ? p.notdone : '...';
  });
}
document.querySelectorAll('input[name="category"]').forEach(r => {
  r.addEventListener('change', function() {
    updatePlaceholders(this.value);
    document.querySelectorAll('.category-option').forEach(d => {
      d.style.background = '';
      d.style.borderColor = '';
    });
    const div = this.closest('label').querySelector('.category-option');
    if (div) {
      div.style.background = 'color-mix(in srgb, var(--primary) 20%, transparent)';
      div.style.borderColor = 'color-mix(in srgb, var(--primary) 50%, transparent)';
    }
  });
});
// Init first checked
const checked = document.querySelector('input[name="category"]:checked');
if (checked) checked.dispatchEvent(new Event('change'));
updatePlaceholders('شخصي');

// Image preview
function previewImage(input) {
  if (input.files && input.files[0]) {
    if (input.files[0].size > 2 * 1024 * 1024) {
      showToast('حجم الصورة يتجاوز 2 ميجا', 'error');
      input.value = '';
      return;
    }
    const reader = new FileReader();
    reader.onload = function(e) {
      document.getElementById('previewImg').src = e.target.result;
      document.getElementById('imagePreview').classList.remove('hidden');
      document.getElementById('uploadIcon').textContent = '✅';
      document.getElementById('uploadText').textContent = input.files[0].name;
    };
    reader.readAsDataURL(input.files[0]);
  }
}
function removeImage() {
  document.getElementById('imageInput').value = '';
  document.getElementById('imagePreview').classList.add('hidden');
  document.getElementById('uploadIcon').textContent = '📁';
  document.getElementById('uploadText').textContent = 'اضغط لاختيار صورة';
}
</script>
