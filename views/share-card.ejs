<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@400;600;700&display=swap" rel="stylesheet">
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body {
  font-family: 'IBM Plex Sans Arabic', sans-serif;
  background: #0f172a;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 20px;
}
.card {
  width: 500px;
  max-width: 100%;
  background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
  border-radius: 24px;
  border: 2px solid rgba(239, 68, 68, 0.3);
  padding: 40px;
  color: #e2e8f0;
}
.header { text-align: center; margin-bottom: 30px; }
.logo { font-size: 14px; color: #94a3b8; margin-bottom: 8px; }
.name { font-size: 28px; font-weight: 700; color: #f1f5f9; }
.meta { display: flex; justify-content: center; gap: 16px; margin-top: 8px; font-size: 13px; color: #64748b; }
.section { margin-bottom: 24px; }
.section-title { font-size: 16px; font-weight: 700; margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
.section-title.done { color: #f87171; }
.section-title.wish { color: #facc15; }
.item {
  background: rgba(255,255,255,0.03);
  border-radius: 12px;
  padding: 12px 16px;
  margin-bottom: 8px;
  font-size: 14px;
  line-height: 1.7;
  display: flex;
  align-items: flex-start;
  gap: 10px;
}
.item-num {
  background: #dc2626;
  color: white;
  width: 24px;
  height: 24px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  font-weight: 700;
  flex-shrink: 0;
  margin-top: 2px;
}
.item-num.wish { background: #ca8a04; }
.footer { text-align: center; margin-top: 30px; padding-top: 20px; border-top: 1px solid rgba(255,255,255,0.06); }
.footer .url { font-size: 12px; color: #475569; }
.footer .brand { font-size: 16px; font-weight: 700; color: #ef4444; margin-bottom: 4px; }
</style>
</head>
<body>
<div class="card">
  <div class="header">
    <div class="logo">أول مرّة — تجارب الناس</div>
    <div class="name">تجربة <%= story.hide_name ? 'مجهول' : story.name %></div>
    <div class="meta">
      <span><%= story.category || 'شخصي' %></span>
      <span>·</span>
      <span><%= new Date(story.created_at).toLocaleDateString('ar-SA') %></span>
    </div>
  </div>

  <% if (doneItems.length) { %>
  <div class="section">
    <div class="section-title done">😔 أشياء ندم عليها</div>
    <% doneItems.forEach(function(item, i) { %>
    <div class="item">
      <span class="item-num"><%= i+1 %></span>
      <span><%= item %></span>
    </div>
    <% }); %>
  </div>
  <% } %>

  <% if (notDoneItems.length) { %>
  <div class="section">
    <div class="section-title wish">✨ أشياء تمنيت لو فعلتها</div>
    <% notDoneItems.forEach(function(item, i) { %>
    <div class="item">
      <span class="item-num wish"><%= i+1 %></span>
      <span><%= item %></span>
    </div>
    <% }); %>
  </div>
  <% } %>

  <% if (story.comment) { %>
  <div class="section">
    <div class="item" style="background:rgba(239,68,68,0.05);border:1px solid rgba(239,68,68,0.1);">
      <span>💬</span>
      <span><%= story.comment %></span>
    </div>
  </div>
  <% } %>

  <div class="footer">
    <div class="brand">أول مرّة</div>
    <div class="url">awwal-time.ksawats.com/story/<%= story.id %></div>
  </div>
</div>
</body>
</html>
